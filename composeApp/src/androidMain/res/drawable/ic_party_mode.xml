        android:strokeColor="#000000"
        android:strokeWidth="1.5"
        android:strokeLineCap="round"
        android:pathData="M11,10 L13,10" />
    <path
        android:strokeColor="#000000"
        android:strokeWidth="1.5"
        android:strokeLineCap="round"
        android:pathData="M12,9 L13,10 L12,11" />
    
    <!-- Music note -->
    <path
        android:fillColor="#000000"
        android:pathData="M19,6 L19,4 L20.5,4.5 L20.5,6 M19,6 C18.2,6 17.5,6.7 17.5,7.5 C17.5,8.3 18.2,9 19,9 C19.8,9 20.5,8.3 20.5,7.5" />
    
    <!-- Second music note -->
    <path
        android:fillColor="#000000"
        android:pathData="M5,7 L5,5 L6.5,5.5 L6.5,7 M5,7 C4.2,7 3.5,7.7 3.5,8.5 C3.5,9.3 4.2,10 5,10 C5.8,10 6.5,9.3 6.5,8.5" />
    
