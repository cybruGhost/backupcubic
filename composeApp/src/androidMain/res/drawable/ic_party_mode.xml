<!-- ic_party_mode.xml -->
<!-- Toggle party mode for synchronized playback -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24"
    android:tint="?attr/colorControlNormal">
    
    <!-- Two people listening together -->
    <!-- Left person -->
    <path
        android:fillColor="#000000"
        android:pathData="M8,14 C8,14 7,16 7,18 L9,18 C9,16 8,14 8,14Z" />
    <path
        android:fillColor="#000000"
        android:pathData="M8,8.5 A2.5,2.5 0 1,1 7.99,8.5 Z" />
    <path
        android:fillColor="#000000"
        android:pathData="M8,14 L6,20 L8,20 L9,16 L10,20 L12,20 L10,14Z" />
    
    <!-- Right person -->
    <path
        android:fillColor="#000000"
        android:pathData="M16,14 C16,14 15,16 15,18 L17,18 C17,16 16,14 16,14Z" />
    <path
        android:fillColor="#000000"
        android:pathData="M16,8.5 A2.5,2.5 0 1,1 15.99,8.5 Z" />
    <path
        android:fillColor="#000000"
        android:pathData="M16,14 L14,20 L16,20 L17,16 L18,20 L20,20 L18,14Z" />
    
    <!-- Sync arrows between them -->
